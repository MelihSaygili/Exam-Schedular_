<Window x:Class="ExamSchedular.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ExamSchedular" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0F172A" Padding="14">
            <StackPanel>
                <TextBlock Text="ExamSchedular"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="18"
                           Margin="0,0,0,16"/>

                <Button Content="Derslikler" Tag="Classrooms" Margin="0,0,0,8" Click="Nav_Click"/>
                <Button Content="Ders Import" Tag="CoursesImport" Margin="0,0,0,8" Click="Nav_Click"/>
                <Button Content="Öğrenci Import" Tag="StudentsImport" Margin="0,0,0,8" Click="Nav_Click"/>
                <Button Content="Ders Listesi" Tag="CoursesList" Margin="0,0,0,8" Click="Nav_Click"/>
                <Button Content="Öğrenci Listesi" Tag="StudentsList" Margin="0,0,0,8" Click="Nav_Click"/>
                <Button Content="Program Oluştur" Tag="Schedule" Margin="0,0,0,8" Click="Nav_Click"/>
                <Button Content="Kullanıcılar" Tag="Users" Margin="0,0,0,8" Click="Nav_Click"/>
                <Button Content="Çıkış" Tag="Logout" Click="Nav_Click" />
            </StackPanel>
        </Border>

        <!-- İçerik Alanı -->
        <ContentControl x:Name="Host" Grid.Column="1"/>
    </Grid>
</Window>
