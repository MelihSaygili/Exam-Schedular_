<UserControl x:Class="ExamSchedular.UI.Views.CoursesListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Ara barı -->
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBox Width="360" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
            <Button Content="Ara" Width="100" Margin="0,0,8,0" Command="{Binding SearchCommand}"/>
            <Button Content="Temizle" Width="100" Command="{Binding ClearCommand}"/>
            <TextBlock Text="{Binding Items.Count, StringFormat=Toplam {0} ders}" Margin="12,0,0,0"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Liste -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  MouseDoubleClick="OnRowDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="120"/>
                <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="*"/>

                <!-- Navigation kolonları -->
                <DataGridTextColumn Header="Öğretim Üyesi" Binding="{Binding Instructor.Name}" Width="220"/>
                <DataGridCheckBoxColumn Header="Zorunlu" Binding="{Binding IsMandatory}" Width="90"/>
                <DataGridTextColumn Header="Bölüm" Binding="{Binding Department.Name}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Margin="0,4,0,0" Foreground="DimGray"
                   Text="{Binding Items.Count, StringFormat=Toplam {0} ders}"/>
    </Grid>
</UserControl>
