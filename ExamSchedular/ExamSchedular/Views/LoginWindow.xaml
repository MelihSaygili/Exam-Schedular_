<Window x:Class="ExamSchedular.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ExamSchedular - Giriş"
        Height="260" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Başlık -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <!-- Email -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <!-- Şifre -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <!-- Hata + Buton -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <TextBlock Grid.Row="0"
                   Text="Giriş Yap"
                   FontSize="20"
                   FontWeight="Bold"/>

        <!-- E-posta -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="E-posta" Margin="0,0,0,4"/>
            <TextBox Height="30"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- Şifre -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Şifre" Margin="0,0,0,4"/>
            <!-- Password, ViewModel'e code-behind üzerinden aktarılıyor -->
            <PasswordBox Height="30" PasswordChanged="Pwd_PasswordChanged"/>
        </StackPanel>

        <!-- Hata + Giriş Butonu -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding Error}"
                       Foreground="IndianRed"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>

            <Button Grid.Column="1"
                    Content="Giriş"
                    Width="90" Height="32"
                    Command="{Binding LoginCommand}"
                    IsDefault="True"/>
        </Grid>
    </Grid>
</Window>
