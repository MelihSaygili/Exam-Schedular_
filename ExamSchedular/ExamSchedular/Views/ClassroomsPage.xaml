<UserControl x:Class="ExamSchedular.UI.Views.ClassroomsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:ExamSchedular.UI.Views.Controls">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Liste -->
        <DockPanel Grid.Column="0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
                <Button Content="Yenile" Width="90" Margin="0,0,8,0" Command="{Binding RefreshCommand}"/>
                <Button Content="Ekle" Width="90" Margin="0,0,8,0" Command="{Binding AddCommand}"/>
                <Button Content="Düzenle" Width="90" Margin="0,0,8,0" Command="{Binding EditCommand}"/>
                <Button Content="Sil" Width="90" Command="{Binding DeleteCommand}"/>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False"
                      CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="*" />
                    <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="Rows" Binding="{Binding Rows}" Width="Auto" />
                    <DataGridTextColumn Header="Cols" Binding="{Binding Columns}" Width="Auto" />
                    <DataGridTextColumn Header="SeatGrp" Binding="{Binding SeatGroupSize}" Width="Auto" />
                    <DataGridTextColumn Header="Kapasite" Binding="{Binding Capacity}" Width="Auto" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Önizleme -->
        <GroupBox Grid.Column="2" Header="Sınıf Önizleme" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Kod: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding Selected.Code}" Margin="6,0,18,0"/>
                    <TextBlock Text="Ad: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding Selected.Name}" Margin="6,0,18,0"/>
                    <TextBlock Text="Rows×Cols: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding Selected.Rows}" />
                    <TextBlock Text=" × " />
                    <TextBlock Text="{Binding Selected.Columns}" />
                </StackPanel>

                <c:SeatGrid Grid.Row="2"
                            Rows="{Binding Selected.Rows}"
                            Columns="{Binding Selected.Columns}"
                            SeatGroupSize="{Binding Selected.SeatGroupSize}"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
