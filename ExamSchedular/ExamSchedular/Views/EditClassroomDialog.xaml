<Window x:Class="ExamSchedular.UI.Views.EditClassroomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:ExamSchedular.UI.Views.Controls"
        Title="Derslik" Height="420" Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <TextBlock Text="Kod" />
            <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

            <TextBlock Text="Ad" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

            <TextBlock Text="Rows" />
            <TextBox Text="{Binding Rows}" Margin="0,0,0,8"/>

            <TextBlock Text="Columns" />
            <TextBox Text="{Binding Columns}" Margin="0,0,0,8"/>

            <TextBlock Text="Seat Group Size (2/3)"/>
            <TextBox Text="{Binding SeatGroupSize}" Margin="0,0,0,8"/>

            <TextBlock Text="Kapasite" />
            <TextBox Text="{Binding Capacity}" IsReadOnly="True" Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Kaydet" Width="90" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
                <Button Content="İptal" Width="90" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </StackPanel>

        <c:SeatGrid Grid.Column="2"
            Rows="{Binding Rows}"
            Columns="{Binding Columns}"
            SeatGroupSize="{Binding SeatGroupSize}"/>
    </Grid>
</Window>
