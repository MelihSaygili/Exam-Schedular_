<UserControl x:Class="ExamSchedular.UI.Views.StudentsListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="Width" Value="280"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Ara barı -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
            <Grid>
                <TextBox x:Name="SearchBox"
                         Style="{StaticResource SearchTextBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <!-- Placeholder -->
                <TextBlock Text="Öğrenci no veya ad..."
                           Margin="6,2,0,0"
                           Foreground="Gray"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Button Content="Ara"
                    Style="{StaticResource ToolbarButton}"
                    Command="{Binding SearchCommand}"/>
            <Button Content="Temizle"
                    Style="{StaticResource ToolbarButton}"
                    Command="{Binding ClearCommand}"/>

            <TextBlock Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding Items.Count, StringFormat=Toplam {0} öğrenci}"/>
        </StackPanel>

        <!-- Liste + Dersler -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Öğrenciler -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedStudent}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Öğrenci No" Binding="{Binding StudentNo}" Width="140"/>
                    <DataGridTextColumn Header="Ad Soyad" Binding="{Binding NameSurname}" Width="*"/>
                    <DataGridTextColumn Header="Sınıf" Binding="{Binding ClassYear}" Width="100"/>
                    <DataGridTextColumn Header="Bölüm" Binding="{Binding Department.Name}" Width="220"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Aldığı Dersler -->
            <GroupBox Grid.Column="2" Header="Aldığı Dersler" Padding="6">
                <DataGrid ItemsSource="{Binding CoursesOfSelected}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kod" Binding="{Binding Code}" Width="120"/>
                        <DataGridTextColumn Header="Ad"  Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Hoca" Binding="{Binding Instructor}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- Durum -->
        <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="Gray"
                   Text="{Binding Status}"/>
    </Grid>
</UserControl>
