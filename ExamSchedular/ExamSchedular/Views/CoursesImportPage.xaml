<UserControl x:Class="ExamSchedular.UI.Views.CoursesImportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Üst araç çubuğu -->
            <RowDefinition Height="Auto"/>
            <!-- DB silme butonları (ALT SATIR) -->
            <RowDefinition Height="8"/>
            <!-- boşluk -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="8"/>
            <!-- boşluk -->
            <RowDefinition Height="Auto"/>
            <!-- Hatalar -->
        </Grid.RowDefinitions>

        <!-- Üst araç çubuğu -->
        <DockPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBox Width="420" Margin="0,0,8,0" Text="{Binding FilePath}" IsReadOnly="True"/>
                <Button Content="Dosya Seç"   Width="100" Margin="0,0,8,0" Command="{Binding ChooseFileCommand}"/>
                <Button Content="Önizle"      Width="100" Margin="0,0,8,0" Command="{Binding LoadPreviewCommand}"/>
                <Button Content="Kaydet"      Width="100" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
                <Button Content="Temizle"     Width="100" Margin="0,0,8,0" Command="{Binding ClearCommand}"/>
                <Button Content="Manuel Ekle" Width="110" Margin="0,0,8,0" Command="{Binding AddEmptyRowCommand}"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Right" Text="{Binding Status}"
                       Foreground="DimGray" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- ALT SATIR: DB Delete Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Button Content="Seçili Dersi DB'den Sil" Width="160" Margin="0,0,8,0"
                    Command="{Binding DeleteSelectedFromDbCommand}"/>
            <Button Content="Tüm Dersleri DB'den Sil"  Width="160"
                    Command="{Binding DeleteAllFromDbCommand}"/>
        </StackPanel>

        <!-- Önizleme / Düzenleme -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True"
                  IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kod"
                                    Binding="{Binding Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="120"/>
                <DataGridTextColumn Header="Ad"
                                    Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"/>
                <DataGridTextColumn Header="Öğretim Üyesi"
                                    Binding="{Binding Instructor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="220"/>
                <DataGridCheckBoxColumn Header="Zorunlu"
                                        Binding="{Binding IsMandatory, Mode=TwoWay}"
                                        Width="90"/>
                <!-- Satırdan Önizleme Sil -->
                <DataGridTemplateColumn Header="" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Sil" Padding="6,2"
                                    Command="{Binding DataContext.DeleteRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Hatalar -->
        <GroupBox Grid.Row="5" Header="Hatalar" Padding="6">
            <ListBox ItemsSource="{Binding Errors}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
    </Grid>
</UserControl>
