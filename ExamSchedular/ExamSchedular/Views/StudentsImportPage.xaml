<UserControl x:Class="ExamSchedular.UI.Views.StudentsImportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Dosya + Butonlar -->
        <DockPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBox Width="420" Margin="0,0,8,0" Text="{Binding FilePath}" IsReadOnly="True"/>
                <Button Content="Dosya Seç" Width="100" Margin="0,0,8,0" Command="{Binding ChooseFileCommand}"/>
                <Button Content="Önizle"   Width="100" Margin="0,0,8,0" Command="{Binding LoadPreviewCommand}"/>
                <Button Content="Kaydet"   Width="100" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
                <Button Content="Temizle"  Width="100" Command="{Binding ClearCommand}"/>
            </StackPanel>
            <TextBlock DockPanel.Dock="Right" Text="{Binding Status}" Foreground="DimGray" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Önizleme -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Öğrenci No" Binding="{Binding StudentNo}" Width="140"/>
                <DataGridTextColumn Header="Ad Soyad"   Binding="{Binding Name}"      Width="230"/>
                <DataGridTextColumn Header="Sınıf"      Binding="{Binding ClassYear}" Width="80"/>
                <DataGridTextColumn Header="Dersler (Kod virgüllü)" Binding="{Binding CoursesCsv}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Hatalar -->
        <GroupBox Grid.Row="4" Header="Hatalar" Padding="6">
            <ListBox ItemsSource="{Binding Errors}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
    </Grid>
</UserControl>
