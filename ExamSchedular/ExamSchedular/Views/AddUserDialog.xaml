<Window x:Class="ExamSchedular.UI.Views.AddUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Koordinatör Ekle" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="E-posta:" VerticalAlignment="Center"/>
        <TextBox Grid.Column="1" x:Name="txtEmail" Width="220" Margin="0,2"/>

        <TextBlock Grid.Row="2" Text="Parola:" VerticalAlignment="Center"/>
        <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="pwd" Width="220" Margin="0,2"/>

        <TextBlock Grid.Row="4" Text="Bölüm:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cmbDept" Width="220"
              DisplayMemberPath="Name" SelectedValuePath="DepartmentId" />

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="İptal" Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Ekle" Width="120" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
