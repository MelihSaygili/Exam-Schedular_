<UserControl x:Class="ExamSchedular.UI.Views.UsersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button Content="Yenile" Width="100" Margin="0,0,8,0" Command="{Binding RefreshCommand}"/>
            <Button Content="Koordinatör Ekle" Width="150" Command="{Binding AddCoordinatorCommand}"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False"
              CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="E-posta" Binding="{Binding Email}" Width="2*"/>
                <DataGridTextColumn Header="Rol" Binding="{Binding Role}" Width="Auto"/>
                <DataGridTextColumn Header="Bölüm" Binding="{Binding Department.Name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
